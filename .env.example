# ── Database ───────────────────────────────────────────────
MM_DB_PATH=money.duckdb

# ── LLM (LiteLLM – provider-agnostic) ─────────────────────
# Just change LLM_MODEL to switch providers. Examples:
#   gpt-4o              → OpenAI
#   ollama/llama3       → local Ollama (no API key needed)
#   gemini/gemini-pro   → Google Gemini
#   anthropic/claude-3  → Anthropic
#   hosted_vllm/model   → self-hosted vLLM

LLM_MODEL=gpt-4o
LLM_API_KEY=sk-your-key-here
# LLM_API_BASE=           # Only needed for self-hosted (Ollama/vLLM)
# LLM_TEMPERATURE=0.2

# ── UPI Transaction Identifiers ───────────────────────────
# Comma-separated narration prefixes that denote UPI transactions.
# Add your own bank-specific terms as needed.
UPI_IDENTIFIERS=UPIOUT,UPIAR

# ── API ────────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000
